<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dunamis Ads — Agência de Inteligência Artificial e Marketing</title>
<meta name="description" content="Dunamis Ads: agência de Inteligência Artificial e Marketing. Marketing com clones de IA, gestão de tráfego pago, automações inteligentes e IA dentro do WhatsApp que trabalha 24h por dia para o seu negócio.">
<meta name="keywords" content="Inteligência Artificial, Marketing Digital, Tráfego Pago, WhatsApp IA, Clones de IA, Automação, Évora, Portugal">
<meta name="author" content="Dunamis Ads">
<meta property="og:title" content="Dunamis Ads — Inteligência Artificial e Marketing">
<meta property="og:description" content="Transformamos negócios com Inteligência Artificial e Resultados.">
<meta property="og:type" content="website">
<meta name="theme-color" content="#090909">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ===================== TOKENS ===================== */
:root{
  --bg:#090909;
  --bg-2:#0c0c0c;
  --panel:#101010;
  --gold:#f5a623;
  --gold-hi:#ffd66e;
  --gold-lo:#c67d17;
  --gold-soft:rgba(245,166,35,.16);
  --gold-line:rgba(245,166,35,.22);
  --white:#f6f5f1;
  --muted:#9a9a93;
  --muted-2:#6f6f68;
  --wa:#25d366;
  --wa-dk:#128c7e;
  --glass:rgba(255,255,255,.035);
  --glass-2:rgba(255,255,255,.05);
  --radius:20px;
  --radius-sm:14px;
  --ease:cubic-bezier(.2,.7,.2,1);
  --shadow:0 24px 60px -20px rgba(0,0,0,.8);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  background:var(--bg);
  color:var(--white);
  font-family:'Inter',system-ui,sans-serif;
  line-height:1.6;
  overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
}
h1,h2,h3,h4,.display{font-family:'Montserrat',sans-serif;line-height:1.05;letter-spacing:-.01em}
a{color:inherit;text-decoration:none}
img{max-width:100%;display:block}
.gold{color:var(--gold)}
.wrap{width:min(1180px,92vw);margin-inline:auto}
section{position:relative}

/* ===================== ATMOSPHERE ===================== */
#particles{position:fixed;inset:0;z-index:0;pointer-events:none}
.aura{position:fixed;z-index:0;pointer-events:none;filter:blur(90px);opacity:.5;border-radius:50%}
.aura.a1{top:-160px;right:-120px;width:520px;height:520px;background:radial-gradient(circle,rgba(245,166,35,.35),transparent 70%)}
.aura.a2{top:40%;left:-200px;width:600px;height:600px;background:radial-gradient(circle,rgba(245,166,35,.14),transparent 70%)}
.cursor-glow{position:fixed;z-index:1;width:460px;height:460px;border-radius:50%;pointer-events:none;
  background:radial-gradient(circle,rgba(245,166,35,.10),transparent 65%);
  transform:translate(-50%,-50%);transition:opacity .4s;mix-blend-mode:screen}
.rays{position:absolute;inset:0;z-index:0;pointer-events:none;opacity:.35;
  background:
    conic-gradient(from 210deg at 78% 42%,transparent 0deg,rgba(245,166,35,.12) 12deg,transparent 26deg,rgba(245,166,35,.08) 40deg,transparent 54deg);
  mix-blend-mode:screen}
main,header,footer{position:relative;z-index:2}

/* ===================== HEADER ===================== */
header{
  position:fixed;top:0;left:0;right:0;z-index:50;
  padding:18px 0;transition:padding .4s var(--ease),background .4s,backdrop-filter .4s,border-color .4s;
  border-bottom:1px solid transparent;
}
header.scrolled{
  padding:10px 0;background:rgba(9,9,9,.72);backdrop-filter:blur(16px) saturate(140%);
  border-bottom:1px solid var(--gold-line);
}
.nav{display:flex;align-items:center;justify-content:space-between;gap:24px}
.brand{display:flex;align-items:center;gap:12px}
.brand img{width:52px;height:52px;object-fit:contain;filter:drop-shadow(0 4px 12px rgba(245,166,35,.35))}
.brand .bt{display:flex;flex-direction:column;line-height:1}
.brand .bt b{font-family:'Montserrat';font-weight:900;font-size:18px;letter-spacing:.02em}
.brand .bt span{font-size:9px;letter-spacing:.24em;color:var(--gold);font-weight:700;margin-top:3px}
.menu{display:flex;gap:30px;list-style:none}
.menu a{font-size:13.5px;font-weight:600;color:#d7d7cf;letter-spacing:.02em;position:relative;padding:4px 0;transition:color .25s}
.menu a::after{content:"";position:absolute;left:0;bottom:-2px;width:0;height:2px;border-radius:2px;
  background:linear-gradient(90deg,var(--gold),var(--gold-hi));transition:width .3s var(--ease)}
.menu a:hover{color:var(--gold)}
.menu a:hover::after{width:100%}
.btn{display:inline-flex;align-items:center;gap:9px;font-weight:700;font-family:'Montserrat';
  border-radius:999px;cursor:pointer;border:none;transition:transform .25s var(--ease),box-shadow .3s;
  white-space:nowrap;letter-spacing:.02em}
.btn svg{width:18px;height:18px;flex:none}
.btn-gold{background:linear-gradient(135deg,var(--gold-hi),var(--gold) 55%,var(--gold-lo));color:#1a1200;
  padding:12px 22px;font-size:13.5px;box-shadow:0 10px 26px -8px rgba(245,166,35,.6),inset 0 1px 0 rgba(255,255,255,.4)}
.btn-gold:hover{transform:translateY(-2px);box-shadow:0 16px 36px -8px rgba(245,166,35,.75)}
.btn-lg{padding:17px 34px;font-size:15px}
.btn-ghost{background:var(--glass-2);color:var(--white);padding:16px 30px;font-size:15px;
  border:1px solid rgba(255,255,255,.14);backdrop-filter:blur(8px)}
.btn-ghost:hover{transform:translateY(-2px);border-color:var(--gold-line);box-shadow:0 0 30px -8px var(--gold-soft)}
.btn-wa{background:linear-gradient(135deg,#2ee06f,var(--wa) 60%,var(--wa-dk));color:#04240f;
  padding:18px 40px;font-size:16px;box-shadow:0 14px 34px -10px rgba(37,211,102,.6)}
.btn-wa:hover{transform:translateY(-2px);box-shadow:0 20px 44px -10px rgba(37,211,102,.8)}
.pulse{animation:pulse 2.6s ease-in-out infinite}
@keyframes pulse{0%,100%{box-shadow:0 10px 26px -8px rgba(245,166,35,.55),0 0 0 0 rgba(245,166,35,.35)}
  50%{box-shadow:0 12px 30px -8px rgba(245,166,35,.7),0 0 0 12px rgba(245,166,35,0)}}
.burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:8px}
.burger span{width:26px;height:2.5px;background:var(--gold);border-radius:2px;transition:.3s}
.mobile-menu{display:none}

/* ===================== HERO ===================== */
.hero{padding:150px 0 80px;overflow:hidden}
.hero-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:40px;align-items:center}
.eyebrow{display:inline-flex;align-items:center;gap:9px;font-size:11.5px;font-weight:700;letter-spacing:.22em;
  text-transform:uppercase;color:var(--gold);background:var(--gold-soft);border:1px solid var(--gold-line);
  padding:8px 16px;border-radius:999px;margin-bottom:26px}
.eyebrow::before{content:"";width:7px;height:7px;border-radius:50%;background:var(--gold);box-shadow:0 0 10px var(--gold)}
.hero h1{font-size:clamp(38px,5.6vw,72px);font-weight:900;text-transform:uppercase}
.hero h1 .gold{background:linear-gradient(120deg,var(--gold-hi),var(--gold));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;
  filter:drop-shadow(0 4px 18px rgba(245,166,35,.35))}
.hero p.lead{color:var(--muted);font-size:clamp(15px,1.5vw,18px);max-width:520px;margin:26px 0 30px}
.mini-feats{display:flex;gap:26px;flex-wrap:wrap;margin-bottom:34px}
.mini{display:flex;align-items:center;gap:11px;max-width:170px}
.mini .ic{width:42px;height:42px;flex:none;border-radius:12px;display:grid;place-items:center;
  background:var(--gold-soft);border:1px solid var(--gold-line);color:var(--gold)}
.mini .ic svg{width:21px;height:21px}
.mini b{font-family:'Montserrat';font-size:12.5px;font-weight:800;text-transform:uppercase;letter-spacing:.03em;line-height:1.2}
.hero-cta{display:flex;align-items:center;gap:24px;flex-wrap:wrap}
.phone{display:inline-flex;align-items:center;gap:9px;font-weight:700;font-size:17px;color:var(--white)}
.phone svg{width:18px;height:18px;color:var(--gold)}
.hero-visual{position:relative;display:grid;place-items:center}
.hero-visual .halo{position:absolute;width:118%;height:118%;border-radius:50%;
  background:radial-gradient(circle,rgba(245,166,35,.32),transparent 62%);filter:blur(30px);animation:breathe 6s ease-in-out infinite}
@keyframes breathe{0%,100%{transform:scale(1);opacity:.85}50%{transform:scale(1.06);opacity:1}}
.hero-visual img{position:relative;width:100%;border-radius:22px;
  filter:drop-shadow(0 30px 60px rgba(0,0,0,.7));animation:float 7s ease-in-out infinite}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}

/* ===================== SECTION HEADS ===================== */
.sec-head{text-align:center;margin-bottom:56px}
.sec-head .kicker{font-size:12px;font-weight:700;letter-spacing:.26em;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:14px}
.sec-head h2{font-size:clamp(28px,3.6vw,46px);font-weight:900;text-transform:uppercase}
.sec-head p{color:var(--muted);max-width:600px;margin:16px auto 0;font-size:16px}
.pad{padding:100px 0}

/* ===================== SERVICES ===================== */
.cards-4{display:grid;grid-template-columns:repeat(4,1fr);gap:22px}
.card{position:relative;background:var(--glass);border:1px solid rgba(255,255,255,.08);border-radius:var(--radius);
  padding:34px 26px;text-align:center;overflow:hidden;transition:transform .4s var(--ease),border-color .4s,box-shadow .4s;
  transform-style:preserve-3d;backdrop-filter:blur(8px)}
.card::before{content:"";position:absolute;inset:0;border-radius:inherit;padding:1px;opacity:0;transition:opacity .4s;
  background:linear-gradient(135deg,var(--gold),transparent 40%);-webkit-mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);-webkit-mask-composite:xor;mask-composite:exclude}
.card::after{content:"";position:absolute;top:-40%;left:50%;width:200px;height:200px;transform:translateX(-50%);
  background:radial-gradient(circle,var(--gold-soft),transparent 70%);opacity:0;transition:opacity .4s;pointer-events:none}
.card:hover{transform:translateY(-10px);border-color:var(--gold-line);box-shadow:0 30px 60px -24px rgba(245,166,35,.35)}
.card:hover::before,.card:hover::after{opacity:1}
.card .cic{width:74px;height:74px;margin:0 auto 22px;border-radius:18px;display:grid;place-items:center;
  background:linear-gradient(160deg,rgba(245,166,35,.16),rgba(245,166,35,.04));border:1px solid var(--gold-line);
  color:var(--gold);transition:transform .4s var(--ease)}
.card:hover .cic{transform:translateY(-4px) scale(1.06)}
.card .cic svg{width:36px;height:36px}
.card h3{font-size:16px;font-weight:800;text-transform:uppercase;letter-spacing:.02em;margin-bottom:12px;min-height:40px;display:flex;align-items:center;justify-content:center}
.card p{color:var(--muted);font-size:14px;margin-bottom:22px}
.card .more{display:inline-flex;align-items:center;gap:7px;font-family:'Montserrat';font-weight:700;font-size:12px;
  letter-spacing:.06em;text-transform:uppercase;color:var(--gold);border:1px solid var(--gold-line);
  padding:9px 18px;border-radius:999px;transition:.3s}
.card .more:hover{background:var(--gold);color:#1a1200}

/* ===================== WHY / BENEFITS ===================== */
.why-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
.why{display:flex;align-items:center;gap:14px;padding:20px;border-radius:var(--radius-sm);
  background:var(--glass);border:1px solid rgba(255,255,255,.07);transition:.35s var(--ease)}
.why:hover{border-color:var(--gold-line);transform:translateY(-4px);background:var(--glass-2)}
.why .wic{width:44px;height:44px;flex:none;border-radius:12px;display:grid;place-items:center;color:var(--gold);
  background:var(--gold-soft);border:1px solid var(--gold-line)}
.why .wic svg{width:22px;height:22px}
.why b{font-family:'Montserrat';font-size:13.5px;font-weight:700;line-height:1.25}

/* ===================== EXPERT + TESTIMONIAL ===================== */
.duo{display:grid;grid-template-columns:1.05fr .95fr;gap:34px;align-items:stretch}
.panel{background:var(--glass);border:1px solid rgba(255,255,255,.08);border-radius:var(--radius);padding:40px;backdrop-filter:blur(8px)}
.expert{display:grid;grid-template-columns:1.2fr 1fr;gap:30px;align-items:center}
.kicker-sm{font-size:11.5px;font-weight:700;letter-spacing:.24em;text-transform:uppercase;color:var(--gold);margin-bottom:14px;display:block}
.expert h3{font-size:clamp(26px,3vw,38px);font-weight:900;text-transform:uppercase;margin-bottom:18px}
.expert .desc{color:var(--muted);font-size:15px;margin-bottom:22px}
.checks{list-style:none;display:flex;flex-direction:column;gap:12px}
.checks li{display:flex;align-items:center;gap:11px;font-size:14.5px;font-weight:500}
.checks .cbox{width:24px;height:24px;flex:none;border-radius:7px;display:grid;place-items:center;color:#1a1200;
  background:linear-gradient(135deg,var(--gold-hi),var(--gold));font-size:13px;font-weight:900}
.expert-photo{position:relative;display:grid;place-items:center;aspect-ratio:1;min-height:260px}
.expert-photo::before{content:"";position:absolute;width:92%;height:92%;border-radius:50%;
  background:radial-gradient(circle,rgba(245,166,35,.30),transparent 68%);filter:blur(28px);animation:breathe 6s ease-in-out infinite}
.expert-img{position:relative;width:100%;border-radius:50%;
  box-shadow:0 0 46px -6px rgba(245,166,35,.5),0 22px 50px -14px rgba(0,0,0,.75);
  animation:float 7s ease-in-out infinite}
.ring{position:absolute;inset:0;margin:auto;width:100%;height:100%;border-radius:50%;
  border:2px solid transparent;background:conic-gradient(from 0deg,var(--gold),transparent 30%,var(--gold-hi) 60%,transparent 80%,var(--gold)) border-box;
  -webkit-mask:linear-gradient(#000 0 0) padding-box,linear-gradient(#000 0 0);-webkit-mask-composite:xor;mask-composite:exclude;
  animation:spin 12s linear infinite;filter:drop-shadow(0 0 18px rgba(245,166,35,.5))}
@keyframes spin{to{transform:rotate(360deg)}}
.expert-photo .avatar{width:82%;height:82%;border-radius:50%;overflow:hidden;position:relative;
  background:radial-gradient(circle at 50% 30%,#1a1a1a,#050505);display:grid;place-items:end center}
.expert-photo .avatar .silh{width:88%;color:#2b2b2b}
.expert-photo .avatar .init{position:absolute;inset:0;display:grid;place-items:center;
  font-family:'Montserrat';font-weight:900;font-size:56px;color:rgba(245,166,35,.9);letter-spacing:.04em;
  text-shadow:0 4px 24px rgba(245,166,35,.4)}

.tst{display:flex;flex-direction:column}
.tst-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:22px}
.tst-track{position:relative;flex:1;min-height:180px}
.tslide{position:absolute;inset:0;opacity:0;transform:translateX(20px);transition:opacity .5s,transform .5s;pointer-events:none}
.tslide.on{opacity:1;transform:none;pointer-events:auto}
.stars{color:var(--gold);font-size:18px;letter-spacing:2px;margin-bottom:16px}
.tslide .quote{font-size:16px;line-height:1.55;margin-bottom:24px;color:#efeee8}
.tslide .who{display:flex;align-items:center;gap:14px}
.tslide .who .pic{width:48px;height:48px;border-radius:50%;flex:none;display:grid;place-items:center;
  font-family:'Montserrat';font-weight:800;color:#1a1200;background:linear-gradient(135deg,var(--gold-hi),var(--gold))}
.tslide .who b{display:block;font-size:14.5px}
.tslide .who span{font-size:12.5px;color:var(--gold)}
.tst-nav{display:flex;gap:10px}
.tst-nav button,.tarrow{width:40px;height:40px;border-radius:50%;border:1px solid var(--gold-line);background:var(--glass-2);
  color:var(--gold);cursor:pointer;display:grid;place-items:center;transition:.3s}
.tst-nav button:hover{background:var(--gold);color:#1a1200}
.dots{display:flex;gap:7px;margin-top:20px}
.dots i{width:8px;height:8px;border-radius:50%;background:rgba(245,166,35,.3);cursor:pointer;transition:.3s}
.dots i.on{background:var(--gold);width:22px;border-radius:5px}

/* ===================== STATS ===================== */
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:0;margin-top:40px;
  background:var(--glass);border:1px solid rgba(255,255,255,.08);border-radius:var(--radius);overflow:hidden;backdrop-filter:blur(8px)}
.stat{padding:34px 24px;display:flex;align-items:center;gap:16px;border-right:1px solid rgba(255,255,255,.06);transition:background .3s}
.stat:last-child{border-right:none}
.stat:hover{background:var(--gold-soft)}
.stat .sic{width:52px;height:52px;flex:none;border-radius:14px;display:grid;place-items:center;color:var(--gold);
  background:var(--gold-soft);border:1px solid var(--gold-line)}
.stat .sic svg{width:26px;height:26px}
.stat .num{font-family:'Montserrat';font-weight:900;font-size:30px;line-height:1;
  background:linear-gradient(120deg,var(--gold-hi),var(--gold));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
.stat .lbl{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-top:6px}

/* ===================== PROCESS ===================== */
.timeline{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;position:relative}
.timeline::before{content:"";position:absolute;top:38px;left:12%;right:12%;height:2px;
  background:linear-gradient(90deg,transparent,var(--gold-line),var(--gold),var(--gold-line),transparent);z-index:0}
.step{position:relative;z-index:1;text-align:center}
.step .n{width:76px;height:76px;margin:0 auto 20px;border-radius:50%;display:grid;place-items:center;
  font-family:'Montserrat';font-weight:900;font-size:26px;color:var(--gold);
  background:radial-gradient(circle,#141414,#0a0a0a);border:2px solid var(--gold-line);
  box-shadow:0 0 0 6px rgba(9,9,9,1),0 10px 30px -8px rgba(245,166,35,.4);transition:.4s var(--ease)}
.step:hover .n{color:#1a1200;background:linear-gradient(135deg,var(--gold-hi),var(--gold));transform:translateY(-6px) scale(1.05)}
.step h4{font-size:16px;font-weight:800;text-transform:uppercase;margin-bottom:8px}
.step p{color:var(--muted);font-size:13.5px}

/* ===================== CTA ===================== */
.cta{padding:0 0 100px}
.cta-box{position:relative;border-radius:32px;padding:64px 40px;text-align:center;overflow:hidden;
  background:linear-gradient(135deg,#20160a,#3a2708 40%,#20160a);border:1px solid var(--gold-line)}
.cta-box::before{content:"";position:absolute;inset:0;opacity:.5;
  background:radial-gradient(circle at 20% 20%,rgba(245,166,35,.35),transparent 45%),radial-gradient(circle at 80% 80%,rgba(245,166,35,.25),transparent 45%)}
.cta-box > *{position:relative}
.cta-box h2{font-size:clamp(26px,3.4vw,44px);font-weight:900;text-transform:uppercase;margin-bottom:18px}
.cta-box p{color:#e8dcc2;max-width:560px;margin:0 auto 34px;font-size:16px}
.cta-actions{display:flex;align-items:center;justify-content:center;gap:26px;flex-wrap:wrap}

/* ===================== FLOAT WA ===================== */
.wa-float{position:fixed;right:24px;bottom:24px;z-index:60;display:flex;align-items:center;gap:12px;
  background:linear-gradient(135deg,#2ee06f,var(--wa));color:#04240f;padding:14px 20px 14px 16px;border-radius:999px;
  font-weight:700;font-size:14px;box-shadow:0 14px 34px -8px rgba(37,211,102,.6);transition:transform .3s var(--ease);
  animation:waIn .6s .8s both}
.wa-float:hover{transform:translateY(-3px) scale(1.03)}
.wa-float .wc{width:40px;height:40px;border-radius:50%;background:rgba(255,255,255,.25);display:grid;place-items:center}
.wa-float .wc svg{width:26px;height:26px;color:#fff}
.wa-float .wc::after{content:"";position:absolute;width:40px;height:40px;border-radius:50%;
  background:rgba(255,255,255,.4);animation:ring 2.2s ease-out infinite}
@keyframes ring{0%{transform:scale(1);opacity:.6}100%{transform:scale(1.8);opacity:0}}
@keyframes waIn{from{transform:translateY(30px);opacity:0}to{transform:none;opacity:1}}
.wa-float .txt{display:flex;flex-direction:column;line-height:1.15;max-width:100px}
.wa-float .txt small{font-weight:600;font-size:12px}

/* ===================== FOOTER ===================== */
footer{border-top:1px solid rgba(255,255,255,.07);padding:64px 0 30px;margin-top:20px;background:var(--bg-2)}
.foot-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1.2fr;gap:40px}
.foot-brand img{width:120px;margin-bottom:16px;filter:drop-shadow(0 6px 16px rgba(245,166,35,.3))}
.foot-brand p{color:var(--muted);font-size:14px;max-width:260px}
.foot-col h5{font-family:'Montserrat';font-size:12px;font-weight:800;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);margin-bottom:18px}
.foot-col ul{list-style:none;display:flex;flex-direction:column;gap:11px}
.foot-col ul li a,.foot-col ul li{color:var(--muted);font-size:14px;transition:color .25s;display:flex;align-items:center;gap:10px}
.foot-col ul li a:hover{color:var(--gold)}
.foot-col ul li svg{width:16px;height:16px;color:var(--gold);flex:none}
.socials{display:flex;gap:12px;margin-top:8px}
